from flask import Flask, jsonify
from flask_cors import CORS
import requests

app = Flask(__name__)
CORS(app)

FUELEST_BASE = "https://fuelest.ee"

@app.route("/api/stations")
def get_stations():
    try:
        r = requests.get(
            f"{FUELEST_BASE}/Home/GetStationsWithPrices",
            headers={"Referer": FUELEST_BASE, "X-Requested-With": "XMLHttpRequest"},
            timeout=8
        )
        return jsonify(r.json())
    except Exception as e:
        return jsonify({"error": str(e)}), 500

@app.route("/api/prices/<int:fuel_type>")
def get_prices(fuel_type):
    try:
        r = requests.get(
            f"{FUELEST_BASE}/Home/GetLatestPrices",
            params={"fuelTypeId": fuel_type, "countryId": 1},
            headers={"Referer": FUELEST_BASE, "X-Requested-With": "XMLHttpRequest"},
            timeout=8
        )
        return jsonify(r.json())
    except Exception as e:
        return jsonify({"error": str(e)}), 500

@app.route("/api/history/<int:fuel_type>")
def get_history(fuel_type):
    try:
        r = requests.get(
            f"{FUELEST_BASE}/Home/GetPriceHistory",
            params={"fuelTypeId": fuel_type, "countryId": 1, "days": 7},
            headers={"Referer": FUELEST_BASE, "X-Requested-With": "XMLHttpRequest"},
            timeout=8
        )
        return jsonify(r.json())
    except Exception as e:
        return jsonify({"error": str(e)}), 500

@app.route("/health")
def health():
    return jsonify({"status": "ok"})

if __name__ == "__main__":
    app.run(port=5001, debug=True)        return jsonify(r.json())
    except Exception as e:
        return jsonify({"error": str(e)}), 500

@app.route("/api/prices/<int:fuel_type>")
def get_prices(fuel_type):
    try:
        r = requests.get(
            f"{FUELEST_BASE}/Home/GetLatestPrices",
            params={"fuelTypeId": fuel_type, "countryId": 1},
            headers={"Referer": FUELEST_BASE, "X-Requested-With": "XMLHttpRequest"},
            timeout=8
        )
        return jsonify(r.json())
    except Exception as e:
        return jsonify({"error": str(e)}), 500

@app.route("/api/history/<int:fuel_type>")
def get_history(fuel_type):
    try:
        r = requests.get(
            f"{FUELEST_BASE}/Home/GetPriceHistory",
            params={"fuelTypeId": fuel_type, "countryId": 1, "days": 7},
            headers={"Referer": FUELEST_BASE, "X-Requested-With": "XMLHttpRequest"},
            timeout=8
        )
        return jsonify(r.json())
    except Exception as e:
        return jsonify({"error": str(e)}), 500

@app.route("/health")
def health():
    return jsonify({"status": "ok"})

if __name__ == "__main__":
    app.run(port=5001, debug=True)
```

